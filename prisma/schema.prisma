// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// المستخدمين
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  birthDate     DateTime?
  gender        String?
  bloodType     String?
  image         String?
  language      String   @default("ar") // ar | en
  points        Int      @default(0)
  level         Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  diagnoses      Diagnosis[]
  medicalRecords MedicalRecord[]
  medications    Medication[]
  chatSessions   ChatSession[]
  favoriteDoctors FavoriteDoctor[]
  notifications  Notification[]
  reviews        Review[]
  sharedResults  SharedResult[]
  pointsHistory  PointsHistory[]
}

// التشخيصات
model Diagnosis {
  id              String   @id @default(cuid())
  userId          String
  symptoms        String   // JSON string
  analysis        String   // JSON string - نتائج التحليل
  recommendation  String?  // التوصية
  specialty       String?  // التخصص المناسب
  severity        String?  // degree of severity
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedResults   SharedResult[]
}

// السجل الطبي
model MedicalRecord {
  id              String   @id @default(cuid())
  userId          String
  type            String   // نوع السجل (مرض مزمن، عملية، حساسية...)
  title           String
  description     String?
  date            DateTime?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// الأدوية
model Medication {
  id              String   @id @default(cuid())
  userId          String
  name            String
  dosage          String?
  frequency       String?
  startDate       DateTime?
  endDate         DateTime?
  reminders       Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// المحادثات
model ChatSession {
  id              String   @id @default(cuid())
  userId          String
  title           String?
  messages        String   // JSON string
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// الأطباء المفضلين
model FavoriteDoctor {
  id              String   @id @default(cuid())
  userId          String
  name            String
  specialty       String
  address         String?
  phone           String?
  notes           String?
  lat             Float?
  lng             Float?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// الإشعارات
model Notification {
  id              String   @id @default(cuid())
  userId          String
  type            String   // appointment | reminder | points | system
  title           String
  message         String
  data            String?  // JSON string
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// التقييمات
model Review {
  id              String   @id @default(cuid())
  userId          String
  doctorName      String
  specialty       String
  rating          Int      // 1-5
  comment         String?
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// مشاركة النتائج
model SharedResult {
  id              String   @id @default(cuid())
  userId          String
  diagnosisId     String?
  shareCode       String   @unique // كود للمشاركة
  expiresAt       DateTime?
  views           Int      @default(0)
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagnosis       Diagnosis? @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
}

// سجل النقاط
model PointsHistory {
  id              String   @id @default(cuid())
  userId          String
  points          Int
  reason          String   // diagnosis | chat | review | share
  description     String?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
